                <span class="work-number">{work.number}</span>
                <span class="label">{work.label}</span>
              </div>
              <h3>{work.title}</h3>
              <p>{work.description}</p>
              <div class="tag-list" aria-label={`${work.title} tags`}>
                {work.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section reveal" id="credentials">
        <div class="section-heading">
          <span>05 CREDENTIALS</span>
          <div>
            <h2>Education & Certs</h2>
            <p>
              Formal education across cybersecurity, cloud security, business,
              military leadership, and technical risk management.
            </p>
