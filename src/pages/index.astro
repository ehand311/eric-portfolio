                    <img
                      src={group.logoUrl}
                      alt=""
                      width="40"
                      height="40"
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                  <div>
                    <span class="label">{group.eyebrow}</span>
                    <h3>{group.title}</h3>
                    <p>{group.items[0]}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <section class="credential-panel reveal-child" aria-labelledby="certifications-heading">
            <h3 class="subsection-title" id="certifications-heading">Certifications</h3>
            <div class="certification-stack">
              {certifications.map((group) => (
                <article class="cert-card reveal-child">
                  <div class="card-title">
                    <span class="logo-tile" aria-hidden="true">
                      <img
                        src={group.logoUrl}
                        alt=""
                        width="40"
                        height="40"
                        loading="lazy"
                        decoding="async"
                      />
