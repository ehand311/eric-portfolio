<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(:root) {
    --bg: #2c2c2b;
    --panel: #343433;
    --panel-strong: #3d3d3b;
    --text: #f4f2ec;
    --muted: #a8adb9;
    --muted-strong: #c7cbd4;
    --accent: #d7ad45;
    --line: rgba(244, 242, 236, 0.16);
    --line-strong: rgba(215, 173, 69, 0.75);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
    --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  :global(html) {
    scroll-behavior: smooth;
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
  }

  :global(body) {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent 360px),
      var(--bg);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    min-height: 78px;
    padding: 18px clamp(22px, 5vw, 68px);
    background: rgba(44, 44, 43, 0.9);
    backdrop-filter: blur(16px);
  }

  .brand {
    display: grid;
    place-items: center;
    min-width: 104px;
    height: 42px;
    padding: 0 12px;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(14px, 2vw, 28px);
    font-family: var(--mono);
    font-size: 13px;
  }

  nav a {
    color: var(--muted-strong);
  }

  nav a::before {
    color: var(--accent);
  }

  nav a:nth-child(1)::before {
    content: "01. ";
  }

  nav a:nth-child(2)::before {
    content: "02. ";
  }

  nav a:nth-child(3)::before {
    content: "03. ";
  }

  nav a:nth-child(4)::before {
    content: "04. ";
  }

  nav a:nth-child(5)::before {
    content: "05. ";
  }

  nav a:nth-child(6)::before {
    content: "06. ";
  }

  nav a:hover,
  .social-rail a:hover,
  .email-rail a:hover {
    color: var(--accent);
  }

  main {
    width: min(1040px, calc(100% - 48px));
    margin: 0 auto;
  }

  .social-rail,
  .email-rail {
    position: fixed;
    top: 50%;
    z-index: 15;
    display: flex;
    align-items: center;
    color: var(--muted-strong);
  }

  .social-rail {
    left: 48px;
    flex-direction: column;
    gap: 20px;
    transform: translateY(-50%);
  }

  .social-rail a {
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
  }

  .social-rail svg {
    display: block;
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .email-rail {
    right: 48px;
    flex-direction: column;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    transform: translateY(-50%);
    writing-mode: vertical-rl;
  }

  .social-rail::after,
  .email-rail::after {
    content: "";
    display: block;
    width: 1px;
    height: 92px;
    margin-top: 24px;
    background: var(--muted);
    opacity: 0.65;
  }

  .email-rail::after {
    margin-top: 28px;
  }

  .medium-icon {
    width: 22px;
    height: 22px;
  }

  .hero {
    display: grid;
    min-height: calc(100vh - 78px);
    padding: clamp(34px, 5vw, 62px) 0 72px;
    align-items: start;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 34px;
    align-items: start;
  }

  .eyebrow,
  .role,
  .section-heading span,
  .contact span,
  .label,
  time,
  .job-heading span {
    color: var(--accent);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.5;
  }

  .eyebrow {
    margin: 0 0 24px;
  }

  h1 {
    max-width: 930px;
    margin: 0;
    color: var(--text);
    font-size: clamp(42px, 6.5vw, 70px);
    line-height: 1.05;
    letter-spacing: 0;
  }

  h1 span {
    display: block;
    margin-top: 10px;
    color: var(--muted);
  }

  .role {
    margin: 22px 0 0;
  }

  .intro {
    max-width: 690px;
    margin: 20px 0 0;
    color: var(--muted-strong);
    font-size: 18px;
    line-height: 1.65;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 13px 18px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1;
  }

  .actions a:hover {
    background: rgba(215, 173, 69, 0.12);
    transform: translateY(-1px);
  }

  .actions svg {
    display: block;
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .actions svg path:not([fill="none"]) {
    fill: currentColor;
    stroke: none;
  }

  .status-panel {
    max-width: 760px;
    border-left: 2px solid var(--accent);
    padding: 18px 0 18px 22px;
  }

  .status-panel p,
  .status-panel span {
    margin: 0;
    color: var(--muted);
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.6;
    text-transform: uppercase;
  }

  .status-panel span {
    display: block;
    white-space: nowrap;
  }

  .status-panel strong {
    display: block;
    margin: 18px 0 10px;
    color: var(--text);
    font-size: 24px;
    line-height: 1;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    margin-bottom: 22px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .stats div {
    min-height: 132px;
    padding: 24px 20px;
    background: rgba(255, 255, 255, 0.02);
    text-align: center;
  }

  .stats strong {
    display: block;
    color: var(--text);
    font-size: 36px;
    line-height: 1;
  }

  .stats span {
    display: block;
    margin-top: 12px;
    color: var(--muted);
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.5;
  }

  .marquee {
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .marquee p {
    margin: 0;
    padding: 14px 0;
    color: var(--muted);
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.5;
    text-align: center;
  }

  .section,
  .contact {
    padding: clamp(86px, 11vw, 136px) 0;
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 14px;
    margin-bottom: 42px;
  }

  .section-heading span {
    display: flex;
    align-items: center;
    gap: 18px;
    font-size: 18px;
  }

  .section-heading span::after {
    content: "";
    display: block;
    width: min(320px, 35vw);
    height: 1px;
    background: var(--line);
  }

  .section-heading h2,
  .contact h2 {
    margin: 0;
    color: var(--text);
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.08;
  }

  .section-heading p,
  .contact p,
  .about-copy p,
  article p,
  li,
  .summary {
    color: var(--muted-strong);
    font-size: 17px;
    line-height: 1.65;
  }

  .section-heading p,
  .contact p {
    max-width: 720px;
    margin: 8px 0 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 320px);
    gap: 64px;
    align-items: start;
  }

  .about-copy p {
    margin: 0;
  }

  .about-copy p + p {
    margin-top: 18px;
  }

  .skill-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px 20px;
    max-width: 620px;
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
  }

  .skill-list li {
    position: relative;
    padding-left: 20px;
    font-family: var(--mono);
    font-size: 13px;
  }

  .skill-list li::before,
  article li::before,
  .job-body li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .portrait-frame {
    position: relative;
    margin: 0;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
  }

  .portrait-frame::after {
    content: "";
    position: absolute;
    inset: 24px -18px -18px 24px;
    z-index: -1;
    border: 2px solid var(--accent);
    border-radius: 16px;
  }

  .portrait-frame img {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    border: 1px solid var(--line);
    border-radius: 10px;
    filter: saturate(0.78) contrast(1.02);
    object-fit: cover;
  }

  .focus-grid,
  .credential-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  article {
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.025);
    padding: 28px;
    transition:
      border-color 160ms ease,
      transform 160ms ease,
      background 160ms ease;
  }

  article:hover {
    border-color: rgba(215, 173, 69, 0.45);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  article h3 {
    margin: 0;
    color: var(--text);
    font-size: 22px;
    line-height: 1.2;
  }

  .focus-card-heading {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 18px;
  }

  .focus-icon {
    display: grid;
    flex: 0 0 auto;
    place-items: center;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(215, 173, 69, 0.55);
    color: var(--accent);
    background: rgba(215, 173, 69, 0.08);
  }

  .focus-icon svg {
    display: block;
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  article p {
    margin: 0;
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  article li,
  .job-body li {
    position: relative;
    padding-left: 22px;
  }

  li + li {
    margin-top: 10px;
  }

  .timeline {
    display: grid;
    gap: 18px;
  }

  .timeline article {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr);
    gap: 26px;
    border-left: 2px solid transparent;
  }

  .timeline article:first-child {
    border-left-color: var(--accent);
  }

  time,
  .job-heading span {
    color: var(--accent);
    font-size: 13px;
  }

  .job-heading {
    display: flex;
    justify-content: space-between;
    gap: 24px;
  }

  .company-title,
  .card-title {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .card-title {
    margin-bottom: 18px;
  }

  .logo-tile {
    display: grid;
    flex: 0 0 auto;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.12);
  }

  .logo-tile img {
    display: block;
    max-width: 32px;
    max-height: 32px;
    border-radius: 2px;
    object-fit: contain;
  }

  .job-heading h3,
  .job-heading p,
  .summary {
    margin: 0;
  }

  .job-heading p {
    margin-top: 6px;
    color: var(--muted-strong);
    font-size: 18px;
    line-height: 1.4;
  }

  .summary {
    max-width: 800px;
    margin-top: 18px;
  }

  .job-body ul {
    max-width: 830px;
    margin-top: 20px;
  }

  .label {
    display: inline-block;
    margin-bottom: 18px;
    font-size: 12px;
    text-transform: uppercase;
  }

  .contact {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .contact .actions {
    justify-content: center;
  }

  .reveal,
  .reveal-child {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 700ms ease,
      transform 700ms ease;
    will-change: opacity, transform;
  }

  .reveal-child {
    transform: translateY(20px);
    transition-duration: 620ms;
  }

  .reveal.is-visible,
  .reveal-child.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .stats .reveal-child:nth-child(2),
  .focus-grid .reveal-child:nth-child(2),
  .credential-grid .reveal-child:nth-child(2) {
    transition-delay: 90ms;
  }

  .stats .reveal-child:nth-child(3),
  .focus-grid .reveal-child:nth-child(3),
  .credential-grid .reveal-child:nth-child(3) {
    transition-delay: 180ms;
  }

  .stats .reveal-child:nth-child(4),
  .focus-grid .reveal-child:nth-child(4),
  .credential-grid .reveal-child:nth-child(4) {
    transition-delay: 270ms;
  }

  .timeline .reveal-child:nth-child(2) {
    transition-delay: 80ms;
  }

  .timeline .reveal-child:nth-child(3) {
    transition-delay: 160ms;
  }

  .timeline .reveal-child:nth-child(4) {
    transition-delay: 240ms;
  }

  .timeline .reveal-child:nth-child(5) {
    transition-delay: 320ms;
  }

  .timeline .reveal-child:nth-child(6) {
    transition-delay: 400ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .reveal-child {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 1120px) {
    .social-rail,
    .email-rail {
      display: none;
    }
  }

  @media (max-width: 860px) {
    .site-header {
      position: static;
      display: block;
      min-height: 0;
    }

    nav {
      justify-content: flex-start;
      margin-top: 18px;
    }

    main {
      width: min(100% - 36px, 1040px);
    }

    .hero {
      min-height: auto;
      padding-top: 64px;
    }

    .hero-grid,
    .about-grid,
    .timeline article {
      grid-template-columns: 1fr;
    }

    .status-panel {
      max-width: 360px;
    }

    .status-panel span {
      white-space: normal;
    }

    .stats,
    .focus-grid,
    .credential-grid,
    .skill-list {
      grid-template-columns: 1fr;
    }

    .stats div {
      min-height: auto;
    }

    .job-heading {
      display: block;
    }

    .job-heading span {
      display: block;
      margin-top: 10px;
    }

    .portrait-frame {
      max-width: 320px;
    }
  }

  @media (max-width: 560px) {
    .actions a {
      width: 100%;
      text-align: center;
    }

    .section-heading span::after {
      width: 96px;
    }
  }
</style>
