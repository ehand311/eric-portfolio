                <h3>{area.title}</h3>
              </div>
              <ul>
                {area.points.map((point) => <li>{point}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section reveal" id="experience">
        <div class="section-heading">
          <span>03 EXPERIENCE</span>
          <div>
            <h2>Where I've Been</h2>
            <p>
              A career spanning security engineering, platform risk, privacy,
              data governance, product systems, and military leadership.
            </p>
          </div>
        </div>

        <div class="timeline">
          {experience.map((job) => (
            <article class="reveal-child">
              <time>{job.dates}</time>
              <span class="timeline-marker" aria-hidden="true"></span>
              <div class="job-body">
                <div class="job-heading">
                  <div>
                    <div class="company-title">
                      <span class="logo-tile" aria-hidden="true">
                        <img
                          src={job.logoUrl}
                          alt=""
                          width="40"
                          height="40"
                          loading="lazy"
                          decoding="async"
                        />
                      </span>
                      <h3>{job.company}</h3>
                    </div>
                    <p>{job.role}</p>
                  </div>
                  <span>{job.location}</span>
                </div>

                <p class="summary">{job.summary}</p>

                <ul>
                  {job.highlights.map((highlight) => <li>{highlight}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section reveal" id="work">
