                    <svg viewBox="0 0 24 24">
                      <path d="M12 3 5 6v5.5c0 4.1 2.7 7.9 7 9.5 4.3-1.6 7-5.4 7-9.5V6l-7-3Z" />
                      <path d="m9.4 12 1.8 1.8 3.7-4" />
