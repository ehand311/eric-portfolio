                      <path d="M8.2 13.2h7.6M10.4 10.8h3.2M10.4 15.6h3.2" />
                    </svg>
                  )}
                  {area.icon === "systems" && (
                    <svg viewBox="0 0 24 24">
                      <path d="M4 5.5h7v5H4zM13 5.5h7v5h-7zM4 13.5h7v5H4zM13 13.5h7v5h-7z" />
                    </svg>
                  )}
                  {area.icon === "leadership" && (
                    <svg viewBox="0 0 24 24">
                      <path d="M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM17 11a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM3.5 19c.5-3.3 2.5-5 5.5-5s5 1.7 5.5 5M14.5 14.3c2.8.2 4.6 1.8 5 4.7" />
                    </svg>
                  )}
